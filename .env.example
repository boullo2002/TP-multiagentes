# App
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Graph
GRAPH_MAX_ITERATIONS=12

# LLM (OpenAI-compatible)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tp-multiagentes

# Storage
DATA_DIR=/app/data

# Safety
DEFAULT_LIMIT=50
SQL_SAFETY_STRICTNESS=strict

# MCP
MCP_SERVER_URL=http://mcp:7000
MCP_REQUEST_TIMEOUT_MS=120000

# Postgres (container)
POSTGRES_USER=dvd_user
POSTGRES_PASSWORD=dvd_pass
POSTGRES_DB=dvdrental
POSTGRES_PORT=5432

