# App
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Graph
GRAPH_MAX_ITERATIONS=12
# Límite de pasos del grafo LangGraph (separado de GRAPH_MAX_ITERATIONS; subir si hay muchos reintentos SQL).
GRAPH_RECURSION_LIMIT=100
QUERY_SQL_RETRY_MAX=2
# Fallback LLM para routing de intención (seguridad): se usa solo en casos ambiguos.
INTENT_FALLBACK_ENABLED=true
INTENT_FALLBACK_CONFIDENCE_THRESHOLD=0.65
# Fallback LLM del planner (refina tablas/supuestos cuando el plan heurístico es débil).
PLANNER_FALLBACK_ENABLED=true
PLANNER_FALLBACK_CONFIDENCE_THRESHOLD=0.55

# LLM (OpenAI-compatible) — usada por el SERVICIO `app` para llamar al proveedor LLM
# (LangChain ChatOpenAI → LLM_BASE_URL). No es la misma que UI_OPENAI_API_KEY.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
# Timeout en segundos por llamada al LLM (evita esperas indefinidas si el proxy va lento).
LLM_REQUEST_TIMEOUT=120

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=examen

# Storage (user_preferences.json y schema_context.json viven bajo DATA_DIR; ver README)
DATA_DIR=/app/data

# Safety (defaults de entorno; pueden sobreescribirse en user_preferences.json)
DEFAULT_LIMIT=50
SQL_SAFETY_STRICTNESS=strict

# MCP
MCP_SERVER_URL=http://mcp:7000
MCP_REQUEST_TIMEOUT_MS=120000

# Postgres (container)
POSTGRES_USER=dvd_user
POSTGRES_PASSWORD=dvd_pass
POSTGRES_DB=dvdrental
POSTGRES_PORT=5432

# Open WebUI (servicio `ui`) — spec: spec-ui-openaiweb.md, detalle: ui/README.md
# API_BASE_URL del spec = origen sin /v1; Open WebUI usa OPENAI_API_BASE_URLS con /v1 al final.
UI_OPENAI_API_BASE_URLS=http://app:8000/v1
# UI_OPENAI_API_KEY: clave que Open WebUI envía al HABLAR CON TU BACKEND (Authorization
# hacia .../v1/...). El backend suele no validarla; puede ser "dummy".
# NO es LLM_API_KEY (esa es para que `app` hable con el proveedor LLM).
UI_PORT=3000
WEBUI_SECRET_KEY=change-me-openaiweb
UI_OPENAI_API_KEY=dummy
UI_ENABLE_SIGNUP=true
# ENABLE_PERSISTENT_CONFIG=false va en docker-compose para que la UI use siempre OPENAI_API_* del entorno.

# Schema Agent Streamlit front
SCHEMA_UI_PORT=8501
SCHEMA_AGENT_BACKEND_URL=http://app:8000
